alias fig='fgrep --exclude-dir=.git --exclude-dir=.allure_results -I'
alias gig='grep --exclude-dir=.git --exclude-dir=.allure_results -I'

alias calc='bc -q'
alias pearl='perl -w -mstrict'
alias refl='rsync --exclude=.git --exclude=.allure_results --exclude=.allure_report --exclude=__pycache__ --exclude=.pytest_cache'
alias arch='tree -a'

alias tabs='vi -p'
alias panes='vi -o'
alias cols='vi -O'

alias myconf='/usr/bin/git --git-dir=$HOME/myconf.git/ --work-tree=$HOME'
